{
  "name": "canary-lab",
  "version": "0.10.0",
  "description": "E2E test scaffolder and runner with agent-assisted self-fixing workflows",
  "keywords": [
    "playwright",
    "e2e",
    "testing",
    "test-runner",
    "local-development",
    "observability",
    "developer-tools",
    "ai-agents",
    "claude",
    "codex"
  ],
  "author": {
    "name": "Fer Terahadi",
    "email": "fernanditerahadi@gmail.com",
    "url": "https://github.com/ferterahadi/canary-lab"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferterahadi/canary-lab.git"
  },
  "bugs": {
    "url": "https://github.com/ferterahadi/canary-lab/issues"
  },
  "homepage": "https://github.com/ferterahadi/canary-lab#readme",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "bin": {
    "canary-lab": "dist/scripts/cli.js"
  },
  "exports": {
    "./feature-support/playwright-base": "./dist/shared/configs/playwright.base.js",
    "./feature-support/load-env": "./dist/shared/configs/loadEnv.js",
    "./feature-support/log-marker-fixture": "./dist/shared/e2e-runner/log-marker-fixture.js",
    "./feature-support/types": "./dist/shared/launcher/types.js"
  },
  "files": [
    "dist",
    "tools/fix-node-pty-permissions.mjs",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node tools/prepare-assets.mjs && vite build --config apps/web/vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:web": "vite build --config apps/web/vite.config.ts",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "canary-lab:run": "node dist/scripts/cli.js run",
    "canary-lab:env": "node dist/scripts/cli.js env",
    "canary-lab:new-feature": "node dist/scripts/cli.js new-feature",
    "postinstall": "node tools/fix-node-pty-permissions.mjs",
    "prepack": "npm run build",
    "smoke:pack": "node tools/smoke-pack.mjs",
    "publish:package": "node tools/publish-package.mjs",
    "changelog": "node tools/generate-changelog.mjs",
    "changelog:preview": "node tools/generate-changelog.mjs --dry-run",
    "tag": "node tools/tag-release.mjs",
    "tag:force": "node tools/tag-release.mjs --force"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.12",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@playwright/mcp": "^0.0.71",
    "@playwright/test": "^1.54.2",
    "ast-types": "^0.16.1",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "mammoth": "^1.12.0",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "recast": "^0.23.11",
    "shiki": "^4.0.2",
    "typescript": "^5.9.3",
    "ws": "^8.20.0"
  }
}

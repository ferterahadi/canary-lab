{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "feature.config.ts",
    "e2e/**/*",
    "src/**/*",
    "scripts/**/*",
    "playwright.config.ts"
  ]
}
